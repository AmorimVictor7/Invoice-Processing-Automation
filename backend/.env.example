# ─── OCR ───────────────────────────────────────────────────────────────────────
# Provider: tesseract | google | gemini
OCR_PROVIDER=gemini

# Google Vision API Key (required only if OCR_PROVIDER=google)
GOOGLE_VISION_API_KEY=

# Gemini API Key (required only if OCR_PROVIDER=gemini)
GEMINI_API_KEY=

# Gemini model to use
# Options: gemini-2.0-flash | gemini-2.0-flash-lite | gemini-2.5-pro-preview-05-06
GEMINI_MODEL=gemini-2.0-flash

# Path to Tesseract executable (Windows only)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# ─── AUTENTICAÇÃO ──────────────────────────────────────────────────────────────
# Segredos JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_SECRET

# Validade dos tokens
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Permitir registro público de novos usuários (true | false)
ALLOW_REGISTRATION=true

# ─── REDIS ─────────────────────────────────────────────────────────────────────
# URL de conexão Redis para sessões persistentes.
# Se não configurado, usa memória RAM (não persiste entre restarts).
REDIS_URL=redis://localhost:6379/0

# TTL das sessões em segundos (padrão: 7200 = 2 horas)
SESSION_TTL_SECONDS=7200

# ─── ARMAZENAMENTO ─────────────────────────────────────────────────────────────
# Diretório para arquivos temporários (padrão: diretório temp do sistema)
TEMP_STORAGE_PATH=

# ─── SERVIDOR ──────────────────────────────────────────────────────────────────
APP_ENV=development
SERVER_PORT=8000

# URL do frontend para CORS
FRONTEND_URL=http://localhost:3000
