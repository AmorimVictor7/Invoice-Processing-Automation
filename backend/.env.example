# OCR Provider: google | tesseract
OCR_PROVIDER=tesseract

# Google Vision API Key (required only if OCR_PROVIDER=google)
GOOGLE_VISION_API_KEY=

# Path to Tesseract executable (Windows example)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Temporary storage path (defaults to system temp dir)
TEMP_STORAGE_PATH=

# Application environment
APP_ENV=development

# Server port
SERVER_PORT=8000

# CORS origin for frontend
FRONTEND_URL=http://localhost:3000
